# ==========================================
# UG Backend — Environment Variables
# Copy to .env and fill in real values
# ==========================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ug-security

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# MSG91 (SMS Gateway for device commands)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=UGALRM
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_COUNTRY_CODE=91

# Device Command Password (embedded in device firmware)
DEVICE_PASSWORD=PWD123

# Firebase Admin SDK (base64-encoded service account JSON)
# Run: cat serviceAccountKey.json | base64
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_firebase_service_account

# Webhook security (shared secret between SMS gateway and backend)
WEBHOOK_SECRET=your_webhook_shared_secret

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
